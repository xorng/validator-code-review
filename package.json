{
  "name": "@xorng/validator-code-review",
  "version": "0.1.0",
  "description": "XORNG Code Review Validator - MCP server for code quality analysis",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "xorng-validator-code-review": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "npx tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "vitest",
    "clean": "rm -rf dist",
    "docker:build": "docker build -t xorng/validator-code-review .",
    "docker:run": "docker run -i xorng/validator-code-review"
  },
  "keywords": [
    "ai",
    "mcp",
    "code-review",
    "validator",
    "xorng"
  ],
  "author": "XORNG",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "eslint": "^9.16.0",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.18.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/XORNG/validator-code-review.git"
  }
}
